{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Game in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": false,
      "runtimeArgs": [
        "--auto-open-devtools-for-tabs"
      ]
    },
    {
      "name": "Debug Game in Chrome (Mobile)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": false,
      "runtimeArgs": [
        "--auto-open-devtools-for-tabs",
        "--user-agent=Mozilla/5.0 (Linux; Android 13) AppleWebKit/537.36 Chrome/120.0.0.0 Mobile Safari/537.36"
      ]
    }
  ]
}
